# ── Graphify Integration for Qwen Gate ─────────────────────────────
#
# Usage:
#   1. Copy this file: cp .env.graphify .env
#   2. Or source it: source .env.graphify
#   3. Start graphify: npx graphify@latest
#
# This template configures graphify to use qwen-gate as the OpenAI-compatible
# backend for knowledge graph generation from code, docs, and other content.
#
# ── API Configuration ─────────────────────────────────────────────

# OpenAI-compatible API key (matches qwen-gate API_KEY in .env)
# Leave empty if qwen-gate has no auth, or set to your API_KEY value
OPENAI_API_KEY=test-key-123

# Qwen Gate endpoint — graphify connects here instead of OpenAI
GRAPHIFY_OPENAI_BASE_URL=http://localhost:3001/v1

# ── Model Selection ───────────────────────────────────────────────

# Model to use for graph generation (optional)
# Available: qwen3.5-plus, qwen3.7-max, qwen3.6-plus, etc.
GRAPHIFY_OPENAI_MODEL=qwen3.5-plus

# ── Timeout / Performance ─────────────────────────────────────────

# Request timeout in seconds (optional, default: 60)
# Increase for large codebases or complex graph operations
GRAPHIFY_TIMEOUT=120
